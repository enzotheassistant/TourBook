# Supabase Configuration (Required for app to function)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-side only (never expose in browser)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Mapbox for address autocomplete
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk_live_...

# Phase 4+: RLS Testing (optional for development)
# Set to 'true' in development to test RLS enforcement
# WARNING: In production, do NOT enable RLS testing mode
PHASE4_RLS_TEST_MODE=false

# Phase 5 legacy compatibility endpoint flags (default enabled when unset)
# Set to false to return HTTP 410 for the legacy endpoint.
LEGACY_SHOWS_API_ENABLED=true
LEGACY_GUEST_LIST_API_ENABLED=true
LEGACY_AI_INTAKE_API_ENABLED=true

# Phase 7 Batch 3: Invite delivery + operations
# Optional app base URL for invite links in emails
INVITE_APP_BASE_URL=http://localhost:3000
# Optional display name in invite emails
INVITE_EMAIL_APP_NAME=TourBook
# Provider selector: "resend" for live provider, unset/other -> no-op log adapter
INVITE_EMAIL_PROVIDER=
# Required when INVITE_EMAIL_PROVIDER=resend
INVITE_EMAIL_FROM=TourBook <invites@example.com>
RESEND_API_KEY=
